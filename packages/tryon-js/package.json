{
  "name": "@beear/tryon",
  "version": "0.4.0",
  "description": "BeeAR virtual try-on core library (fit, landmarks, canvas overlay) for Web and Android WebView",
  "type": "module",
  "main": "dist/beear-tryon.js",
  "module": "src/index.js",
  "browser": "dist/beear-tryon.js",
  "unpkg": "dist/beear-tryon.js",
  "jsdelivr": "dist/beear-tryon.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/beear-tryon.js",
      "default": "./dist/beear-tryon.js"
    },
    "./dist/beear-tryon.js": "./dist/beear-tryon.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build-iife.mjs",
    "test": "node --test tests/*.test.mjs",
    "prepack": "npm run build && npm test"
  },
  "keywords": [
    "beear",
    "try-on",
    "glasses",
    "webview",
    "canvas",
    "mergeos",
    "ar"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mergeos-bounties/BeeAR.git",
    "directory": "packages/tryon-js"
  },
  "bugs": {
    "url": "https://github.com/mergeos-bounties/BeeAR/issues"
  },
  "homepage": "https://github.com/mergeos-bounties/BeeAR/tree/master/packages/tryon-js#readme"
}
